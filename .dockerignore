# Docker build context exclusions
# This file tells Docker which files/folders to exclude from the build context

# Version control
.git
.gitignore
.github

# Python
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.egg
.venv
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
coverage.xml

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Documentation
docs/
*.md
!README.md

# Test files
tests/
test_*.py
*_test.py

# Development
.env
.env.*.local
.env.local
docker-compose.override.yml
.docker/
docker/compose

# CI/CD
.github/
.gitea/

# Cache and logs
logs/
*.log
.cache/

# Temporary files
tmp/
temp/
*.tmp

# Node modules (if any frontend)
node_modules/
npm-debug.log
yarn.lock

# Old/backup files
*.bak
*.old
*.orig
